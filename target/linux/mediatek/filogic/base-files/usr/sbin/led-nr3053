#!/bin/sh
# Viettel NR3053: green = WAN link + Internet, red = offline.

GRN=/sys/class/leds/nr3053:green
RED=/sys/class/leds/nr3053:red

board_nr3053() {
	[ "$(cat /tmp/sysinfo/board_name 2>/dev/null)" = "viettel,nr3053" ]
}

led_paths() {
	[ -d "$GRN" ] || GRN=/sys/class/leds/green:status
	[ -d "$RED" ] || RED=/sys/class/leds/red:status
}

wan_ok() {
	local carrier

	[ -d /sys/class/net/wan ] || return 1
	carrier="$(cat /sys/class/net/wan/carrier 2>/dev/null)"
	carrier="${carrier:-0}"
	[ "$carrier" = "1" ] || return 1
	ip link show wan 2>/dev/null | grep -q "state UP" || return 1
	ping -c 1 -W 2 -I wan 1.1.1.1 >/dev/null 2>&1 && return 0
	ping -c 1 -W 2 -I wan 8.8.8.8 >/dev/null 2>&1
}

led_update() {
	led_paths
	[ -d "$GRN" ] && [ -d "$RED" ] || return 1

	echo none > "$RED/trigger" 2>/dev/null
	echo none > "$GRN/trigger" 2>/dev/null

	if wan_ok; then
		echo 0 > "$RED/brightness"
		echo 255 > "$GRN/brightness"
	else
		echo 255 > "$RED/brightness"
		echo 0 > "$GRN/brightness"
	fi
}

led_watch() {
	local last cur

	last=init
	while true; do
		if wan_ok; then cur=1; else cur=0; fi
		if [ "$cur" != "$last" ] || [ ! -d "$GRN" ]; then
			led_update && last="$cur"
		fi
		sleep 5
	done
}

board_nr3053 || exit 0

case "$1" in
watch)  led_watch ;;
update) led_update ;;
*)      led_update ;;
esac
