#!/bin/sh /etc/rc.common
# SPDX-License-Identifier: GPL-2.0-only

START=99
STOP=10
USE_PROCD=1

start_service() {
	[ "$(cat /tmp/sysinfo/board_name 2>/dev/null)" = "viettel,nr3053" ] || return 0

	/usr/sbin/led-nr3053 update

	procd_open_instance
	procd_set_param command /usr/sbin/led-nr3053 watch
	procd_set_param respawn
	procd_close_instance
}
