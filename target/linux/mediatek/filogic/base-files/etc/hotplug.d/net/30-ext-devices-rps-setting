#!/bin/sh

NPROCS="$(grep -c "^processor.*:" /proc/cpuinfo)"
case "$NPROCS" in
    2) RPS_CPUS=1 ;; # set to CPU0
    4) RPS_CPUS=8 ;; # set to CPU3
    *) exit ;;
esac

IFNAME_PREFIX="${INTERFACE%%[0-9]*}"

is_ext_device() {
    case "$IFNAME_PREFIX" in
        usb|wwan)
            return 0
            ;;
        eth)
            # check GMAC compatible node, for ext devices always return 0
            ! grep -q "mediatek,eth-mac" "/sys/class/net/${INTERFACE}/of_node/compatible" 2>/dev/null
            ;;
        *)
            return 1
            ;;
    esac
}

if is_ext_device; then
    if [ "$ACTION" = "add" ]; then
        # set target interface rps
        RPS_FILE="/sys/class/net/${INTERFACE}/queues/rx-0/rps_cpus"
        # rps file sanity check
        if [ -f "$RPS_FILE" ]; then
            echo "$RPS_CPUS" > "$RPS_FILE"
        fi
    fi
    [ -f /etc/init.d/mtk_smp ] && /etc/init.d/mtk_smp restart
fi
