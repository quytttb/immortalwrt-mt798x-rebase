{
	"luci-app-nr3053-throughwall": {
		"description": "Grant access to NR3053 ThroughWall WiFi boost settings",
		"read": {
			"file": {
				"/usr/bin/throughwall-eeprom-read": [ "exec" ]
			},
			"ubus": {
				"luci": [ "setInitAction" ],
				"file": [ "exec" ]
			},
			"uci": [ "throughwall" ]
		},
		"write": {
			"file": {
				"/usr/bin/throughwall-eeprom-read": [ "exec" ]
			},
			"ubus": {
				"luci": [ "setInitAction" ],
				"file": [ "exec" ],
				"system": [ "reboot" ]
			},
			"uci": [ "throughwall" ]
		}
	}
}
