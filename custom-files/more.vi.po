msgstr "Có %d máy kết nối IPv4 duy nhất"
msgid "%d IPv6-only hosts"
msgstr "Có %d máy kết nối IPv6 duy nhất"
msgid "%d dual-stack hosts"
msgstr "%d mạng có dual-stack"
msgid "%s and %s"
msgstr "%s và %s"
msgid "%s, %s and %s"
msgstr "%s, %s và %s"
msgid "-1 - Restart every last day of month"
msgstr "-1 - Khởi động lại vào ngày cuối cùng của tháng"
msgid "-7 - Restart a week before end of month"
msgstr "-7 - Khởi động lại một tuần trước ngày cuối cùng của tháng"
msgid "1 - Restart every 1st of month"
msgstr "1 - Tự động tái khởi động vào ngày số 1 hàng tháng"
msgid "10m - frequent commits at the expense of flash wear"
msgstr "10 phút - cam kết dữ liệu liên tục làm tăng mức hao mòn bộ nhớ flash"
msgid "12h - compromise between risk of data loss and flash wear"
msgstr "12 giờ - Đạt điều kiện với một số bộ nhớ flash cũ nhưng bù lại rủi ro mất hụt dữ liệu không nhiều"
msgid "24h - least flash wear at the expense of data loss risk"
msgstr "24 giờ - Ít hao tổn ổ cứng flash nhất nhưng có thể dẫn tới rủi ro mất dữ liệu"
msgid "30s - refresh twice per minute for reasonably current stats"
msgstr "30 giây - làm mới 2 lần mỗi phút đối với những kết quả thông thường"
msgid "5m - rarely refresh to avoid frequently clearing conntrack counters"
msgstr "5m - hiếm khi làm mới để tránh thường xuyên xóa bộ đếm conntrack"
msgid "60s - commit minutely, useful for non-flash storage"
msgstr "60 giây - thực hiện cam kết từng phút một, hữu hiệu với các bộ nhớ không dùng flash"
msgid "Accounting period"
msgstr "Chu kỳ kế toán"
