msgstr "tắt mạng (ifdown)"
msgid "ifup"
msgstr "kết nối lại (ifup)"
msgid "never"
msgstr "không bao giờ"
msgid "restart"
msgstr "tái khởi động"
msgid "start"
msgstr "bắt đầu"
msgid "stop"
msgstr "dừng"
msgid "unreachable (reject)"
msgstr "Không thể kết nối (từ chối)"
